# --- Groq / LLM ---
GROQ_API_KEY=YOUR_GROQ_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# --- Source data / Ingestion ---
DATA_DIR=data/CRCG_RAG_Dataset
PDF_PATH=data/CRCG_RAG_Dataset/pdf
EXCEL_PATH=data/CRCG_RAG_Dataset/xlsx

# --- Vector store ---
CHROMA_DB_DIR=data/chroma
COLLECTION_NAME=crcg_rag_kb

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K=5
FETCH_K=12

# --- Chunking ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# --- LLM generation ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=600

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
